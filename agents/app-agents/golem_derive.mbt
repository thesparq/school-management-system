///|
impl @config.ConfigField for SharedConfig with collect_entries(path) {
  let entries :Array[@common.AgentConfigDeclaration] = []
  let fp0 = path.copy()
  fp0.push("surreal_host")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp0,
    ),
  )
  let fp1 = path.copy()
  fp1.push("surreal_ns")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp1,
    ),
  )
  let fp2 = path.copy()
  fp2.push("surreal_database")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp2,
    ),
  )
  let fp3 = path.copy()
  fp3.push("surreal_username")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp3,
    ),
  )
  let fp4 = path.copy()
  fp4.push("surreal_password")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp4,
    ),
  )
  let fp5 = path.copy()
  fp5.push("authentik_host")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp5,
    ),
  )
  let fp6 = path.copy()
  fp6.push("authentik_api_token")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp6,
    ),
  )
  let fp7 = path.copy()
  fp7.push("auth_key")
  entries.append(
    @config.collect_entries_of(
      (@schema.TypeTag::{  } : @schema.TypeTag[@config.Secret[String]]),
      fp7,
    ),
  )
  entries
}

