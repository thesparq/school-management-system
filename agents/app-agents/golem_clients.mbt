  student_id : String,
  f : (StudentAgentClient) -> T raise @common.AgentError,
) -> T raise @common.AgentError {
  let client = StudentAgentClient::new_phantom(student_id)
  defer client.drop()
  f(client)
}

///|
pub fn[T] StudentAgentClient::scoped_get_phantom(
  student_id : String,
  phantom_id : @rpcTypes.Uuid,
  f : (StudentAgentClient) -> T raise @common.AgentError,
) -> T raise @common.AgentError {
  let client = StudentAgentClient::get_phantom(student_id, phantom_id)
  defer client.drop()
  f(client)
}

